+def resolveNodeCommand() {
+    if (rootProject.ext.has("nodeExecutable")) {
+        return rootProject.ext.nodeExecutable
+    }
+    def envNode = System.getenv("NODE_BINARY")
+    if (envNode != null && !envNode.trim().isEmpty()) {
+        return envNode.trim()
+    }
+    def candidates = ["/opt/homebrew/bin/node", "/usr/local/bin/node"]
+    for (def candidate : candidates) {
+        if (new File(candidate).exists()) {
+            return candidate
+        }
+    }
+    return "node"
+}
